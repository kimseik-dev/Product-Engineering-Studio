generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id             BigInt          @id @default(autoincrement())
  createdAt      DateTime        @default(now()) @map("created_at")
  title          String
  groupName      String          @map("group_name")
  task           String
  status         String
  area           String
  progress       Int             @default(0)
  endDate        DateTime?       @map("end_date")
  inspectionDate DateTime?       @map("inspection_date")
  issues         Issue[]
  members        ProjectMember[]
  tasks          Task[]

  @@map("projects")
}

model Task {
  id          BigInt         @id @default(autoincrement())
  createdAt   DateTime       @default(now()) @map("created_at")
  content     String
  isCompleted Boolean        @default(false) @map("is_completed")
  priority    String         @default("Medium")
  projectId   BigInt         @map("project_id")
  status      String         @default("To Do")
  progress    Int            @default(0)
  dueDate     DateTime?      @map("due_date")
  assignees   TaskAssignee[]
  project     Project        @relation(fields: [projectId], references: [id])

  @@map("tasks")
}

model Member {
  id        BigInt          @id @default(autoincrement())
  createdAt DateTime        @default(now()) @map("created_at")
  name      String
  role      String
  avatar    String?
  status    String          @default("Active")
  issues    Issue[]         @relation("MemberIssues")
  projects  ProjectMember[]
  tasks     TaskAssignee[]
  posts     Post[]          @relation("MemberPosts")

  @@map("members")
}

model ProjectMember {
  projectId BigInt  @map("project_id")
  memberId  BigInt  @map("member_id")
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, memberId])
  @@map("project_members")
}

model TaskAssignee {
  taskId   BigInt @map("task_id")
  memberId BigInt @map("member_id")
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, memberId])
  @@map("task_assignees")
}

model Setting {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  key       String   @unique
  value     String

  @@map("settings")
}

model Issue {
  id         BigInt   @id @default(autoincrement())
  createdAt  DateTime @default(now()) @map("created_at")
  title      String
  content    String
  status     String   @default("Issue")
  priority   String   @default("Normal")
  projectId  BigInt   @map("project_id")
  assigneeId BigInt?  @map("assignee_id")
  assignee   Member?  @relation("MemberIssues", fields: [assigneeId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id])

  @@map("issues")
}

model Post {
  id         BigInt        @id @default(autoincrement())
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  title      String
  content    String
  imageUrl   String?       @map("image_url")
  authorId   BigInt?       @map("author_id")
  author     Member?       @relation("MemberPosts", fields: [authorId], references: [id])
  categoryId BigInt?       @map("category_id")
  category   PostCategory? @relation(fields: [categoryId], references: [id])

  @@map("posts")
}

model PostCategory {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  name      String   @unique
  label     String
  color     String?
  posts     Post[]

  @@map("post_categories")
}
